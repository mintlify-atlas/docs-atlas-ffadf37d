    "Professional A4 PNG report generation",
    "Backend upload integration (Cloudinary + Airtable)",
    "Adult and pediatric dentition support",
    "17+ treatment types with visual symbols"
  ],
  "publicApiSurface": [
    "$.fn.odontogram() - jQuery plugin initializer",
    "odontogram.setMode(mode) - Set treatment mode",
    "odontogram.redraw() - Redraw canvas",
    "odontogram.setGeometry(geom) - Set tooth geometry",
    "odontogram.getDataURL() - Export canvas image",
    "loadDentalData() - Load FDI tooth data",
    "getToothInfo(fdi) - Get tooth information",
    "getTreatmentName(code) - Get treatment name",
    "generateProfessionalPNG() - Generate report",
    "exportOdontogramData() - Export JSON data",
    "POST /api/upload-odontogram - Upload endpoint"
  ]
